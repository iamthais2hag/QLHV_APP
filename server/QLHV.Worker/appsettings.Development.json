{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "_comment": "PLACEHOLDERS ONLY. Do NOT commit real secrets. Supply real values via user-secrets (dotnet user-secrets) or environment variables.",
  "ConnectionStrings": {
    "QLHV_APP": "Server=__DB_SERVER__;Database=__DB_NAME__;User Id=__DB_USER__;Password=__DB_PASSWORD__;TrustServerCertificate=True;",
    "Hangfire": "Server=__DB_SERVER__;Database=__HANGFIRE_DB__;User Id=__DB_USER__;Password=__DB_PASSWORD__;TrustServerCertificate=True;"
  },
  "Sync": {
    "EnableTargetWrites": false,
    "RequireManualConfirmation": true,
    "AllowHangfireSchedule": false
  }
}
